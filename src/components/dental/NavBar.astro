---
const navLinks = [
  { label: 'Smile Gallery', href: '#' },
  { label: 'Treatments', href: '#' },
  { label: 'Specialists', href: '#' },
  { label: 'Technology', href: '#' },
  { label: 'Reviews', href: '#' },
];
---

<nav class="fixed top-0 w-full z-50 border-b border-slate-200/50 bg-white/70 backdrop-blur-xl transition-all duration-300">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <div class="text-xl font-bold tracking-tighter text-slate-900">
      VitaSmile
    </div>
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a
          class="font-sans text-sm font-medium tracking-tight text-slate-600 hover:text-blue-600 transition-colors"
          href={link.href}
        >
          {link.label}
        </a>
      ))}
    </div>
    <div class="flex items-center gap-4">
      <button class="hidden md:block bg-primary text-white font-sans text-sm font-medium tracking-tight px-5 py-2.5 rounded-full hover:opacity-80 scale-95 active:scale-90 transition-all duration-200 shadow-sm">
        Book Consultation
      </button>
      <button class="md:hidden text-slate-900 p-2">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </div>
</nav>
