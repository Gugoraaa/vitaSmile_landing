---
import TechCard from './TechCard.astro';
import { techFeatures } from '../../data/tech';
---

<section id="tecnologia" data-scroll-section class="mx-auto max-w-container-max px-6 py-section-gap">
  <div data-animate class="text-center mb-16">
    <h2 class="font-h2 text-h2 text-on-surface mb-stack-sm">Digital Smile Transformation</h2>
    <p class="font-body-md text-body-md text-on-surface-variant">Precision at every step of your journey.</p>
  </div>
  <div data-animate-stagger class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    {techFeatures.map(feature => (
      <TechCard icon={feature.icon} title={feature.title} description={feature.description} />
    ))}
  </div>
</section>
