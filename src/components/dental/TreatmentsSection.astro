---
import { featuredTreatments, complementaryTreatments } from '../../data/treatments';
---

<section class="tg-section">
  <div class="tg-container">

    <!-- Encabezado ─────────────────────────────────────────────────────── -->
    <div data-animate class="tg-heading">
      <p class="tg-label">Tratamientos</p>
      <h2 class="font-h2 text-h2 text-on-surface mb-4">Nuestros tratamientos</h2>
      <p class="font-body-md text-body-md text-on-surface-variant max-w-lg mx-auto">
        Nos especializamos en la rehabilitación de tu sonrisa y te ofrecemos todos los tratamientos necesarios para lograrlo.
      </p>
    </div>

    <!-- Grid de 4 cards ─────────────────────────────────────────────────── -->
    <div data-animate class="tg-grid" style="transition-delay:120ms;">
      {featuredTreatments.map((t) => (
        <article class="tg-card">
          <!-- Imagen -->
          <div class="tg-card__media">
            <img src={t.image} alt={t.title} loading="lazy" decoding="async" />
          </div>

          <!-- Contenido -->
          <div class="tg-card__body">
            <div class="tg-card__accent" aria-hidden="true"></div>
            <p class="tg-card__category">{t.category}</p>
            <h3 class="tg-card__title">{t.title}</h3>
            <p class="tg-card__tagline">{t.tagline}</p>
          </div>
        </article>
      ))}
    </div>

    <!-- Tratamientos complementarios ───────────────────────────────────── -->
    <div data-animate class="mt-24" style="transition-delay:80ms;">
      <p class="tg-sublabel">También realizamos</p>
      <div class="tg-band">
        <div class="tg-band__inner">
          {complementaryTreatments.map((t) => (
            <div class="tg-band__item">
              <span class="material-symbols-outlined tg-band__icon">{t.icon}</span>
              <p class="tg-band__name">{t.title}</p>
              <p class="tg-band__desc">{t.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  /* ── Layout ─────────────────────────────────────────────────────────── */
  .tg-section {
    padding: clamp(5.5rem, 8vw, 8rem) 0;
    background: var(--color-surface);
  }

  .tg-container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Encabezado ─────────────────────────────────────────────────────── */
  .tg-heading {
    text-align: center;
    margin-bottom: 4rem;
  }

  .tg-label {
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(6, 27, 49, 0.38);
    margin-bottom: 1.25rem;
  }

  /* ── Grid 2 × 2 ─────────────────────────────────────────────────────── */
  .tg-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .tg-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* ── Card ────────────────────────────────────────────────────────────── */
  .tg-card {
    background: #ffffff;
    border-radius: 1.5rem;
    overflow: hidden;
    border: 1px solid rgba(6, 27, 49, 0.055);
    box-shadow:
      0 4px 24px rgba(6, 27, 49, 0.05),
      0 1px 6px  rgba(6, 27, 49, 0.03);
    transition:
      transform  0.65s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      box-shadow 0.65s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    cursor: default;
  }

  .tg-card:hover {
    transform: translateY(-8px);
    box-shadow:
      0 28px 72px rgba(6, 27, 49, 0.11),
      0  6px 20px rgba(6, 27, 49, 0.06);
  }

  /* ── Imagen ──────────────────────────────────────────────────────────── */
  .tg-card__media {
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: #f0ede9;
  }

  .tg-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .tg-card:hover .tg-card__media img {
    transform: scale(1.05);
  }

  /* ── Contenido ───────────────────────────────────────────────────────── */
  .tg-card__body {
    padding: 1.75rem 1.875rem 2rem;
  }

  /* Barra de acento */
  .tg-card__accent {
    width: 1.75rem;
    height: 2px;
    background: #0066cc;
    margin-bottom: 1.125rem;
    border-radius: 2px;
  }

  .tg-card__category {
    font-size: 0.5625rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: #0066cc;
    margin-bottom: 0.625rem;
  }

  .tg-card__title {
    font-size: 1.25rem;
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.25;
    color: #061b31;
    margin-bottom: 0.75rem;
  }

  .tg-card__tagline {
    font-size: 0.8125rem;
    line-height: 1.65;
    color: rgba(6, 27, 49, 0.48);
    margin-bottom: 1.5rem;
  }


  /* ── Banda complementaria ────────────────────────────────────────────── */
  .tg-sublabel {
    font-size: 0.8125rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    color: rgba(6, 27, 49, 0.65);
    text-align: center;
    margin-bottom: 2.75rem;
  }

  .tg-band {
    border-top: 1px solid rgba(6, 27, 49, 0.08);
    border-bottom: 1px solid rgba(6, 27, 49, 0.08);
  }

  .tg-band__inner {
    display: flex;
    flex-direction: column;
    max-width: 1120px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .tg-band__inner { flex-direction: row; }
  }

  .tg-band__item {
    flex: 1;
    position: relative;
    padding: 2.625rem 2rem;
    text-align: center;
    cursor: default;
    border-bottom: 1px solid rgba(6, 27, 49, 0.08);
    /* línea superior que aparece en hover */
    box-shadow: inset 0 3px 0 transparent;
    transition:
      background-color  0.55s ease,
      box-shadow        0.55s ease;
  }

  .tg-band__item:last-child { border-bottom: none; }

  @media (min-width: 768px) {
    .tg-band__item {
      border-bottom: none;
      border-right: 1px solid rgba(6, 27, 49, 0.08);
    }
    .tg-band__item:last-child { border-right: none; }
  }

  .tg-band__item:hover {
    background: #ffffff;
    box-shadow:
      inset 0 3px 0 #0066cc,
      0 8px 32px rgba(6, 27, 49, 0.05);
  }

  .tg-band__icon {
    font-size: 1.5rem;
    display: block;
    margin-bottom: 1.125rem;
    color: #0066cc;
    transition: color 0.5s ease, transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .tg-band__item:hover .tg-band__icon {
    color: #0066cc;
    transform: translateY(-3px);
  }

  .tg-band__name {
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: #061b31;
    margin-bottom: 0.5rem;
    transition: color 0.5s ease;
  }

  .tg-band__item:hover .tg-band__name { color: #0066cc; }

  .tg-band__desc {
    font-size: 0.75rem;
    line-height: 1.6;
    color: rgba(6, 27, 49, 0.38);
  }
</style>
