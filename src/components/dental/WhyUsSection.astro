---
import FeatureItem from './FeatureItem.astro';
import { features } from '../../data/features';
---

<section id="diferenciales" data-scroll-section class="mx-auto max-w-container-max px-6 py-section-gap">
  <div data-animate class="text-center mb-16">
    <h2 class="font-h2 text-h2 text-on-surface mb-stack-sm">Why Choose VitaSmile</h2>
    <p class="font-body-md text-body-md text-on-surface-variant">Experience dentistry redefined.</p>
  </div>
  <div data-animate-stagger class="grid grid-cols-1 md:grid-cols-2 gap-8">
    {features.map(f => (
      <FeatureItem icon={f.icon} title={f.title} description={f.description} />
    ))}
  </div>
</section>
