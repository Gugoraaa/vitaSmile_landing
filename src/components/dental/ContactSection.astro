---
const clinicAddress = 'Calle Gral. Rafael Buelna Tenorio 854, Primer Cuadro Oriente 3, Culiacan, Sinaloa 80000';
const clinicName = 'Dentistas VitaSmile';
const clinicCoordinates = '24.8117425,-107.385139';
const mapsUrl = 'https://maps.app.goo.gl/bMirNdJckD9tBmK66';
const mapsEmbedQuery = `${clinicCoordinates} (${clinicName})`;
const mapsEmbedUrl = `https://maps.google.com/maps?hl=es&q=${encodeURIComponent(mapsEmbedQuery)}&z=17&ie=UTF8&iwloc=B&output=embed`;
---

<section class="py-section-gap px-6 bg-on-surface">
  <div class="max-w-6xl mx-auto flex flex-col lg:flex-row gap-12 items-center">
    <div class="flex-1 w-full text-center lg:text-left">
      <h2 data-animate class="font-h1 text-h1 text-white mb-stack-lg">Te vemos en tu consulta</h2>
      <p data-animate style="transition-delay: 160ms" class="font-body-lg text-body-lg text-slate-300 mb-8 max-w-xl mx-auto lg:mx-0">
        Comienza tu transformacion con una valoracion personalizada y conoce como nuestros protocolos digitales pueden ayudarte a recuperar la salud y funcion de tu sonrisa con resultados naturales y duraderos.
      </p>
      <div class="mb-10 text-slate-300 font-body-md text-sm space-y-3">
        <a
          data-animate
          style="transition-delay: 300ms"
          href={mapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center lg:justify-start gap-2 hover:text-white transition-colors duration-300"
        >
          <span class="material-symbols-outlined text-primary">location_on</span>
          <span>{clinicAddress}</span>
        </a>
        <p data-animate style="transition-delay: 420ms" class="flex items-start justify-center lg:justify-start gap-2 text-left">
          <span class="material-symbols-outlined text-primary">schedule</span>
          <span class="flex flex-col">
            <span>Previa cita</span>
            <span>Martes y sabado</span>
          </span>
        </p>
        <p data-animate style="transition-delay: 540ms" class="flex items-center justify-center lg:justify-start gap-2">
          <span class="material-symbols-outlined text-primary">call</span>
          +52 667 415 5881
        </p>
      </div>
      <button data-animate style="transition-delay: 660ms" class="bg-primary hover:bg-surface-tint text-on-primary rounded-full px-8 py-4 font-body-md text-body-md shadow-[0_4px_14px_0_rgba(0,102,204,0.39)] transition-transform scale-95 active:scale-90">
        Agenda tu consulta
      </button>
    </div>
    <div data-animate style="transition-delay: 300ms" class="flex-1 w-full">
      <div class="overflow-hidden rounded-[8px] border border-white/10 bg-slate-200 shadow-2xl">
        <iframe
          title="VitaSmile location"
          src={mapsEmbedUrl}
          class="h-[400px] w-full border-0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </div>
</section>
