---
interface Props {
  brand?: string;
  durationMs?: number;
}

const { brand = 'VITASMILE', durationMs = 2800 } = Astro.props;
---

<div class="site-preloader" data-preloader data-preloader-duration={durationMs} aria-hidden="true">
  <div class="site-preloader__inner">
    <p class="site-preloader__brand">{brand}</p>
    <span class="site-preloader__line"></span>
  </div>
</div>

<style is:global>
  :root[data-preloader-stage='active'],
  :root[data-preloader-stage='revealing'],
  :root[data-preloader-stage='active'] body,
  :root[data-preloader-stage='revealing'] body {
    overflow: hidden;
  }

  body > nav,
  body > main,
  body > footer {
    transition:
      transform 920ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 920ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform, opacity;
  }

  :root[data-preloader-stage='active'] body > nav,
  :root[data-preloader-stage='active'] body > main,
  :root[data-preloader-stage='active'] body > footer {
    opacity: 0.74;
    transform: translateY(clamp(1.5rem, 4vh, 3.5rem));
  }

  .site-preloader {
    position: fixed;
    inset: 0;
    z-index: 120;
    display: grid;
    place-items: center;
    padding: 1.5rem;
    background:
      radial-gradient(circle at 50% 18%, rgba(0, 102, 204, 0.18) 0%, rgba(0, 102, 204, 0) 42%),
      linear-gradient(135deg, #061b31 0%, #0b2240 58%, #123055 100%);
    visibility: visible;
    transform: translateY(0);
    will-change: transform;
    transition:
      transform 920ms cubic-bezier(0.76, 0, 0.24, 1),
      visibility 920ms step-end;
  }

  .site-preloader.is-complete {
    visibility: hidden;
    pointer-events: none;
    transform: translateY(-100%);
  }

  .site-preloader__inner {
    display: grid;
    justify-items: center;
    gap: 1rem;
    width: min(100%, 28rem);
  }

  .site-preloader__brand {
    margin: 0;
    padding-left: clamp(0.38em, 1.4vw, 0.62em);
    color: rgba(255, 255, 255, 0.8);
    font-family: var(--font-label-caps);
    font-size: clamp(0.82rem, 1.55vw, 1.08rem);
    font-weight: 300;
    letter-spacing: clamp(0.38em, 1.4vw, 0.62em);
    text-transform: uppercase;
    text-shadow: 0 0 18px rgba(170, 199, 255, 0.1);
    opacity: 0;
    transform: translateY(10px);
    animation:
      preloader-brand-in 900ms cubic-bezier(0.16, 1, 0.3, 1) 120ms forwards,
      preloader-brand-out 620ms cubic-bezier(0.65, 0, 0.35, 1) 2140ms forwards;
  }

  .site-preloader__line {
    display: block;
    width: clamp(9rem, 32vw, 15rem);
    height: 1px;
    border-radius: 999px;
    background: linear-gradient(90deg, transparent 0%, rgba(215, 227, 255, 0.94) 50%, transparent 100%);
    opacity: 0;
    transform: scaleX(0.12);
    transform-origin: center;
    animation:
      preloader-line-flow 1540ms cubic-bezier(0.65, 0, 0.35, 1) 420ms forwards,
      preloader-line-out 560ms cubic-bezier(0.65, 0, 0.35, 1) 2120ms forwards;
  }

  @keyframes preloader-brand-in {
    0% {
      opacity: 0;
      transform: translateY(10px);
    }

    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes preloader-brand-out {
    0% {
      opacity: 1;
      transform: translateY(0);
    }

    100% {
      opacity: 0;
      transform: translateY(-8px);
    }
  }

  @keyframes preloader-line-flow {
    0% {
      opacity: 0;
      transform: scaleX(0.12);
    }

    18% {
      opacity: 0.7;
    }

    58% {
      opacity: 1;
      transform: scaleX(1);
    }

    100% {
      opacity: 1;
      transform: scaleX(1);
    }
  }

  @keyframes preloader-line-out {
    0% {
      opacity: 1;
      transform: scaleX(1);
    }

    100% {
      opacity: 0;
      transform: scaleX(0.4);
    }
  }

  @media (max-width: 640px) {
    .site-preloader {
      padding-inline: 1rem;
    }

    .site-preloader__inner {
      gap: 0.85rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    body > nav,
    body > main,
    body > footer {
      transition: none;
      transform: none;
      opacity: 1;
    }

    .site-preloader__brand,
    .site-preloader__line {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
