---
import BaseHead from '../components/BaseHead.astro';
import Preloader from '../components/Preloader.astro';
import NavBar from '../components/dental/NavBar.astro';
import SiteFooter from '../components/dental/SiteFooter.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html class="light" lang="en" data-preloader-stage="active">
  <head>
    <BaseHead title={title} description={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
  </head>
  <body class="antialiased selection:bg-primary-container selection:text-white">
    <Preloader brand="VITASMILE" />
    <NavBar />
    <main class="pt-24 md:pt-28">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>

<script>
  import gsap from 'gsap';
  import { ScrollToPlugin } from 'gsap/ScrollToPlugin';

  gsap.registerPlugin(ScrollToPlugin);

  type CleanupFn = () => void;
  type WindowWithCleanup = Window & {
    __vitaSmileCleanup?: CleanupFn;
  };

  const globalWindow = window as WindowWithCleanup;
  globalWindow.__vitaSmileCleanup?.();
  const preloaderCompleteEvent = 'vitasmile:preloader-complete';

  const initPreloader = () => {
    const root = document.documentElement;
    const preloader = document.querySelector<HTMLElement>('[data-preloader]');

    if (!preloader) {
      delete root.dataset.preloaderStage;
      window.dispatchEvent(new CustomEvent(preloaderCompleteEvent));
      return () => undefined;
    }

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const totalDuration = Number(preloader.dataset.preloaderDuration ?? '2800');
    const exitDuration = prefersReducedMotion.matches ? 180 : 920;
    const hideDelay = prefersReducedMotion.matches ? 120 : totalDuration;
    let hideTimer = 0;
    let removeTimer = 0;

    root.dataset.preloaderStage = 'active';
    preloader.classList.remove('is-complete');

    hideTimer = window.setTimeout(() => {
      root.dataset.preloaderStage = 'revealing';
      preloader.classList.add('is-complete');

      removeTimer = window.setTimeout(() => {
        delete root.dataset.preloaderStage;
        preloader.remove();
        window.dispatchEvent(new CustomEvent(preloaderCompleteEvent));
      }, exitDuration);
    }, hideDelay);

    return () => {
      window.clearTimeout(hideTimer);
      window.clearTimeout(removeTimer);
      delete root.dataset.preloaderStage;
      preloader.remove();
    };
  };

  const initScrollAnimations = () => {
    let observer: IntersectionObserver | null = null;

    const prepareTypewriterAnimations = () => {
      document.querySelectorAll<HTMLElement>('[data-animate-typewriter]').forEach((element) => {
        if (element.dataset.typewriterReady === 'true') {
          return;
        }

        const sourceText = element.textContent?.replace(/\s+/g, ' ').trim();

        if (!sourceText) {
          return;
        }

        element.dataset.typewriterReady = 'true';
        element.setAttribute('aria-label', sourceText);
        element.textContent = '';

        const fragment = document.createDocumentFragment();
        let characterIndex = 0;

        Array.from(sourceText).forEach((character) => {
          if (character === ' ') {
            fragment.append(document.createTextNode(' '));
            return;
          }

          const span = document.createElement('span');
          span.className = 'typewriter-char';
          span.textContent = character;
          span.style.setProperty('--char-index', `${characterIndex}`);
          span.setAttribute('aria-hidden', 'true');
          fragment.append(span);
          characterIndex += 1;
        });

        element.append(fragment);
      });
    };

    const startObserver = () => {
      if (observer) {
        return;
      }

      observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('animate-in');
              observer?.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('[data-animate-stagger]').forEach((container) => {
        Array.from(container.children).forEach((child, i) => {
          (child as HTMLElement).style.transitionDelay = `${i * 140}ms`;
          child.setAttribute('data-animate', '');
          observer?.observe(child);
        });
      });

      document.querySelectorAll('[data-animate]').forEach((el) => observer?.observe(el));
    };

    prepareTypewriterAnimations();

    if (document.documentElement.dataset.preloaderStage) {
      window.addEventListener(preloaderCompleteEvent, startObserver, { once: true });
    } else {
      startObserver();
    }

    return () => {
      window.removeEventListener(preloaderCompleteEvent, startObserver);
      observer?.disconnect();
    };
  };

  const initSectionScroll = () => {
    const sections = Array.from(document.querySelectorAll<HTMLElement>('[data-scroll-section]'));
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const wheelThreshold = 42;
    const oversizedSectionRatio = 1.08;
    const edgeThreshold = 72;
    const wheelResetDelay = 180;
    const animationDuration = 1.2;
    const postAnimationLockMs = 180;
    const clampIndex = gsap.utils.clamp(0, sections.length - 1);
    let wheelIntent = 0;
    let wheelResetTimer = 0;
    let isAnimating = false;
    let lockUntil = 0;

    if (sections.length < 2 || prefersReducedMotion.matches) {
      return () => undefined;
    }

    const nav = document.querySelector('nav');

    const getOffsetY = () => {
      if (!(nav instanceof HTMLElement)) {
        return 96;
      }

      const rect = nav.getBoundingClientRect();
      return rect.top + rect.height + 12;
    };

    const getSectionStart = (section: HTMLElement) => Math.max(0, section.offsetTop - getOffsetY());

    const getCurrentIndex = () => {
      const probe = window.scrollY + getOffsetY() + Math.min(window.innerHeight * 0.22, 200);
      let activeIndex = 0;

      sections.forEach((section, index) => {
        if (getSectionStart(section) <= probe) {
          activeIndex = index;
        }
      });

      return activeIndex;
    };

    const canLeaveSection = (direction: 1 | -1, section: HTMLElement) => {
      if (section.offsetHeight <= window.innerHeight * oversizedSectionRatio) {
        return true;
      }

      const start = getSectionStart(section);
      const end = start + section.offsetHeight;

      if (direction > 0) {
        return window.scrollY + window.innerHeight >= end - edgeThreshold;
      }

      return window.scrollY <= start + edgeThreshold;
    };

    const isInteractiveTarget = (target: EventTarget | null) =>
      target instanceof Element &&
      Boolean(target.closest('a, button, input, textarea, select, iframe, [contenteditable="true"]'));

    const isTypingTarget = (target: EventTarget | null) =>
      target instanceof Element &&
      Boolean(target.closest('input, textarea, select, [contenteditable="true"]'));

    const isScrollLocked = () => isAnimating || performance.now() < lockUntil;

    const isScrollNavigationKey = (key: string) =>
      ['ArrowDown', 'ArrowUp', 'PageDown', 'PageUp', 'Home', 'End', ' '].includes(key);

    const scrollToSection = (section: HTMLElement) => {
      const hash = section.id ? `#${section.id}` : '';

      isAnimating = true;
      lockUntil = performance.now() + animationDuration * 1000 + postAnimationLockMs;
      wheelIntent = 0;
      window.clearTimeout(wheelResetTimer);
      gsap.killTweensOf(window);
      gsap.to(window, {
        duration: animationDuration,
        ease: 'power3.inOut',
        overwrite: 'auto',
        scrollTo: {
          y: section,
          offsetY: getOffsetY(),
          autoKill: false,
        },
        onComplete: () => {
          isAnimating = false;
          lockUntil = performance.now() + postAnimationLockMs;

          if (hash && window.location.hash !== hash) {
            history.replaceState(null, '', hash);
          }
        },
        onInterrupt: () => {
          isAnimating = false;
          lockUntil = performance.now() + postAnimationLockMs;
        },
      });
    };

    const goToIndex = (index: number) => {
      const targetIndex = clampIndex(index);
      const target = sections[targetIndex];

      if (!target) {
        return;
      }

      scrollToSection(target);
    };

    const onWheel = (event: WheelEvent) => {
      if (isScrollLocked()) {
        if (!event.ctrlKey && Math.abs(event.deltaY) >= Math.abs(event.deltaX)) {
          event.preventDefault();
        }
        wheelIntent = 0;
        return;
      }

      if (
        event.ctrlKey ||
        Math.abs(event.deltaY) < 4 ||
        Math.abs(event.deltaY) < Math.abs(event.deltaX) ||
        isInteractiveTarget(event.target)
      ) {
        return;
      }

      const direction = event.deltaY > 0 ? 1 : -1;
      const currentIndex = getCurrentIndex();
      const currentSection = sections[currentIndex];

      if (!currentSection || !canLeaveSection(direction, currentSection)) {
        wheelIntent = 0;
        return;
      }

      wheelIntent += event.deltaY;
      window.clearTimeout(wheelResetTimer);
      wheelResetTimer = window.setTimeout(() => {
        wheelIntent = 0;
      }, wheelResetDelay);

      if (Math.abs(wheelIntent) < wheelThreshold) {
        return;
      }

      const targetIndex = clampIndex(currentIndex + direction);
      wheelIntent = 0;

      if (targetIndex === currentIndex) {
        return;
      }

      event.preventDefault();
      goToIndex(targetIndex);
    };

    const onKeyDown = (event: KeyboardEvent) => {
      if (isTypingTarget(event.target)) {
        return;
      }

      if (isScrollLocked()) {
        if (isScrollNavigationKey(event.key)) {
          event.preventDefault();
        }
        return;
      }

      const moveDownKeys = ['ArrowDown', 'PageDown', ' '];
      const moveUpKeys = ['ArrowUp', 'PageUp'];
      const shouldMoveDown = moveDownKeys.includes(event.key);
      const shouldMoveUp = moveUpKeys.includes(event.key);

      if (!shouldMoveDown && !shouldMoveUp) {
        return;
      }

      const direction = shouldMoveDown ? 1 : -1;
      const currentIndex = getCurrentIndex();
      const currentSection = sections[currentIndex];

      if (!currentSection || !canLeaveSection(direction, currentSection)) {
        return;
      }

      const targetIndex = clampIndex(currentIndex + direction);

      if (targetIndex === currentIndex) {
        return;
      }

      event.preventDefault();
      goToIndex(targetIndex);
    };

    const onAnchorClick = (event: MouseEvent) => {
      const target = event.target;

      if (!(target instanceof Element)) {
        return;
      }

      const anchor = target.closest<HTMLAnchorElement>('a[href^="#"]');
      const href = anchor?.getAttribute('href');

      if (!anchor || !href || href === '#') {
        return;
      }

      if (isScrollLocked()) {
        event.preventDefault();
        return;
      }

      const section = document.querySelector<HTMLElement>(href);

      if (!section) {
        return;
      }

      event.preventDefault();
      scrollToSection(section);
    };

    window.addEventListener('wheel', onWheel, { passive: false });
    window.addEventListener('keydown', onKeyDown);
    document.addEventListener('click', onAnchorClick);

    return () => {
      window.removeEventListener('wheel', onWheel);
      window.removeEventListener('keydown', onKeyDown);
      document.removeEventListener('click', onAnchorClick);
      window.clearTimeout(wheelResetTimer);
      gsap.killTweensOf(window);
    };
  };

  const cleanupFns = [initPreloader(), initScrollAnimations(), initSectionScroll()];
  globalWindow.__vitaSmileCleanup = () => cleanupFns.forEach((cleanup) => cleanup());
</script>
